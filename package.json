{
  "name": "ascii-file-tree-generator",
  "private": false,
  "version": "1.0.0",
  "description": "Generate clean ASCII file tree diagrams from indented text, uploaded folders, or drag-and-drop directory structures.",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "deploy": "gh-pages -d dist"
  },
  "keywords": [
    "ascii",
    "file-tree",
    "directory-tree",
    "react",
    "vite"
  ],
  "license": "MIT",
  "dependencies": {
    "gh-pages": "^6.3.0",
    "lucide-react": "^0.546.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
